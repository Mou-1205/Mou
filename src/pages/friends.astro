---
import { getEntry, render } from "astro:content";
import Comment from "@components/comment/index.astro";
import FriendCard from "@components/features/friends/FriendCard.astro";
import { PageHeader } from "@components/features/page-header";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import Image from "@components/atoms/Image/Image.astro";

import { siteConfig } from "../config";
import { getShuffledFriendsList } from "../data/friends";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export const prerender = true;

if (!siteConfig.featurePages.friends) {
	return Astro.redirect("/404/");
}

const friendsPost = await getEntry("spec", "friends");

if (!friendsPost) {
	throw new Error("friends page content not found");
}

const { Content } = await render(friendsPost);
const friendsList = getShuffledFriendsList();
const allTags = Array.from(new Set(friendsList.flatMap((item) => item.tags)));
---

<MainGridLayout
	title={i18n(I18nKey.friends)}
	description={i18n(I18nKey.friends)}
>
	<script is:inline>
		window.isFriendsPage = true;
	</script>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<PageHeader
				title={i18n(I18nKey.friends)}
				subtitle={i18n(I18nKey.friendsSubtitle)}
			/>

			<!-- 自我介绍卡片 -->
			<div class="mb-6 p-5 rounded-xl border border-black/10 dark:border-white/10 bg-(--btn-regular-bg)/50">
				<div class="flex items-center gap-4">
					<Image
						src="assets/images/avatar.jpg"
						alt="avatar"
						class="w-14 h-14 rounded-full ring-2 ring-(--primary)/30"
					/>
					<div class="flex-1 min-w-0">
						<div class="flex items-center gap-2">
							<h3 class="text-lg font-bold text-black/90 dark:text-white/90">MouyのHOME</h3>
							<button
								id="copy-friend-info"
								class="text-xs text-black/40 dark:text-white/40 hover:text-(--primary) transition-colors cursor-pointer"
								title="复制友链信息"
							>
								点击复制
							</button>
							<button
								id="copy-friend-config"
								class="text-xs text-black/40 dark:text-white/40 hover:text-(--primary) transition-colors cursor-pointer"
								title="复制友链配置"
							>
								复制配置
							</button>
						</div>
						<p class="text-sm text-black/60 dark:text-white/60 mt-0.5">以好奇心构建，以清晰度交付</p>
						<div class="flex flex-wrap gap-1.5 mt-2">
							<span class="px-2 py-0.5 text-xs rounded-md bg-(--primary)/10 text-(--primary)">技术</span>
							<span class="px-2 py-0.5 text-xs rounded-md bg-(--primary)/10 text-(--primary)">生活</span>
						</div>
					</div>
				</div>

				<!-- 友链申请须知 -->
				<div class="mt-4 pt-4 border-t border-black/5 dark:border-white/5">
					<h4 class="text-sm font-bold text-black/80 dark:text-white/80 mb-2">🔗 友链申请须知</h4>
					<ol class="text-xs text-black/50 dark:text-white/50 space-y-1 list-decimal list-inside">
						<li>请先添加本站友链，确保站点可正常访问</li>
						<li>需有清晰的名称、描述和头像，建站满 1 个月</li>
						<li>拥有原创内容，符合中华人民共和国相关法律法规</li>
						<li>保持一定的更新频率，热爱分享</li>
					</ol>
					<p class="text-xs text-black/40 dark:text-white/40 mt-2">发送邮件至 <span id="copy-email" class="text-(--primary) hover:underline cursor-pointer">2506054842@qq.com</span> 即可申请，邮件标题：友链申请，格式参考：名称、链接、头像、描述、标签</p>
				</div>
			</div>

			<!-- 搜索和筛选栏 -->
			<div class="mb-6 space-y-3">
				<!-- 搜索框 -->
				<div class="w-full">
					<div class="relative">
						<input
							type="text"
							id="friend-search"
							placeholder={i18n(I18nKey.friendsSearchPlaceholder)}
							class="w-full px-4 py-2 pl-10 rounded-lg bg-(--btn-regular-bg)
									text-black/90 dark:text-white/90
									border border-black/10 dark:border-white/10
									focus:outline-none focus:ring-2 focus:ring-(--primary)/50
									transition-all duration-200"
						/>
						<svg
							class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 dark:text-white/40"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
							></path>
						</svg>
					</div>
				</div>

				<!-- 标签筛选 -->
				<div class="filter-container flex flex-wrap gap-2">
					<button class="filter-tag active" data-tag="all">
						{i18n(I18nKey.friendsFilterAll)}
					</button>
					{
						allTags.map((tag) => (
							<button class="filter-tag" data-tag={tag}>
								{tag}
							</button>
						))
					}
				</div>
			</div>

			<!-- 友链卡片网格 -->
			<div
				id="friends-grid"
				class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 mb-6"
			>
				{friendsList.map((item) => <FriendCard friend={item} />)}
			</div>

			<!-- 无结果提示 -->
			<div id="no-results" class="hidden text-center py-12">
				<svg
					class="w-16 h-16 mx-auto mb-4 text-black/20 dark:text-white/20"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
					></path>
				</svg>
				<p class="text-black/50 dark:text-white/50 text-lg">
					{i18n(I18nKey.friendsNoResults)}
				</p>
			</div>

			<!-- 说明文档 -->
			<Markdown class="mt-8 prose dark:prose-invert max-w-none">
				<Content />
			</Markdown>

			<!-- 隐藏元素用于传递 i18n 文本到全局脚本 -->
			<div id="friends-copy-success-text" style="display: none;">
				{i18n(I18nKey.friendsCopySuccess)}
			</div>
		</div>
	</div>

	<!-- 引用全局脚本 -->
	<script is:inline src="/js/friends-page-handler.js"></script>

	<!-- Ping 测速脚本 -->
	<script is:inline>
		(function () {
			function pingUrl(url) {
				return new Promise((resolve) => {
					const start = performance.now();
					const img = new Image();
					let settled = false;
					const done = () => {
						if (settled) return;
						settled = true;
						clearTimeout(timer);
						const ms = Math.round(performance.now() - start);
						resolve(ms);
					};
					img.onload = done;
					img.onerror = done;
					const timer = setTimeout(done, 8000);
					img.src = url + (url.includes("?") ? "&" : "?") + "ping=" + Date.now();
				});
			}

			function formatTime(ms) {
				return (ms / 1000).toFixed(2) + " s";
			}

			async function runPing() {
				const badges = document.querySelectorAll(".ping-badge[data-ping-url]");
				for (const badge of badges) {
					const url = badge.getAttribute("data-ping-url");
					if (!url) continue;
					const ms = await pingUrl(url);
					badge.querySelector(".ping-text").textContent = formatTime(ms);
					badge.classList.remove("opacity-0");
					badge.classList.add("opacity-100");
				}
			}

			// 复制邮箱
			function initCopyEmail() {
				const el = document.getElementById("copy-email");
				if (!el) return;
				el.addEventListener("click", () => {
					navigator.clipboard.writeText("2506054842@qq.com").then(() => {
						const orig = el.textContent;
						el.textContent = "已复制 ✓";
						setTimeout(() => { el.textContent = orig; }, 2000);
					});
				});
			}

			// 复制友链信息
			function initCopyFriendInfo() {
				const btn = document.getElementById("copy-friend-info");
				if (!btn) return;
				btn.addEventListener("click", () => {
					const info =
						"名称：MouyのHOME\n链接：https://mouy.site\n头像：https://mouy.site/assets/images/avatar.jpg\n描述：以好奇心构建，以清晰度交付\n标签：技术、生活";
					navigator.clipboard.writeText(info).then(() => {
						btn.textContent = "已复制 ✓";
						setTimeout(() => {
							btn.textContent = "点击复制";
						}, 2000);
					});
				});
			}

			// 复制友链配置
			function initCopyFriendConfig() {
				const btn = document.getElementById("copy-friend-config");
				if (!btn) return;
				btn.addEventListener("click", () => {
					const config = `{
id: #,
title: "MouyのHOME",
imgurl: "https://mouy.site/_astro/avatar.DRYjHQPD_Z18abIF.webp",
desc: "以好奇心构建，以清晰度交付。",
siteurl: "https://mouy.site/",
tags: ["生活"],
},`;
					navigator.clipboard.writeText(config).then(() => {
						btn.textContent = "已复制 ✓";
						setTimeout(() => {
							btn.textContent = "复制配置";
						}, 2000);
					});
				});
			}

			function init() {
				runPing();
				initCopyFriendInfo();
				initCopyFriendConfig();
				initCopyEmail();
			}

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", init);
			} else {
				init();
			}
		})();
	</script>

	<div class="mt-4">
		<Comment path="/friends/" />
	</div>
</MainGridLayout>

<style>
	/* 搜索框焦点效果 */
	#friend-search:focus {
		box-shadow: 0 0 0 3px var(--primary) / 0.1;
	}

	/* 标签筛选按钮样式 */
	.filter-container {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.filter-tag {
		padding: 0.5rem 1rem;
		border: 1px solid var(--line-divider);
		border-radius: var(--radius-large);
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s ease;
		white-space: nowrap;
	}

	.filter-tag:hover:not(.active) {
		background: var(--btn-hover-bg);
		border-color: var(--primary);
		transform: translateY(-1px);
	}

	.filter-tag.active {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
	}

	.filter-tag.active:hover {
		background: var(--primary) !important;
		color: white !important;
		border-color: var(--primary) !important;
		transform: translateY(-1px);
	}
</style>
